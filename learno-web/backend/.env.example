# ── Server & Environment ──
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
JSON_BODY_LIMIT="20mb"

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/lessono?schema=public"

# ── Authentication & JWT ──
JWT_ACCESS_SECRET="CHANGE_ME_generate_a_64_char_hex_key"
JWT_REFRESH_SECRET="CHANGE_ME_generate_a_64_char_hex_key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Security & Cryptography ──
# Max age for refresh cookie in milliseconds (7 days = 604800000)
COOKIE_MAX_AGE_MS=604800000
SALT_ROUNDS=12

# ── Integrations ──
# Shared secret for FastAPI webhook authentication
WEBHOOK_SECRET="CHANGE_ME_WEBHOOK_SECRET"

# -- Sensor / IoT --
# Enable only when IoT service is running.
SENSOR_INGEST_ENABLED=false
SENSOR_API_URL="http://127.0.0.1:3000/api/latest"
SENSOR_WS_URL="ws://127.0.0.1:3000/ws"
SENSOR_POLL_INTERVAL_MS=5000
# session | always (default: session)
SENSOR_CAPTURE_MODE="session"
# Optional: pin sensor to a class (used when capture mode is "always")
SENSOR_CLASS_ID=""
# Optional: pin sensor device id (used when telemetry has no deviceId)
SENSOR_DEVICE_ID=""

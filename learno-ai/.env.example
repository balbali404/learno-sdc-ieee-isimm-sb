# Gemini AI Configuration (fill in your values)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash
GEMINI_REQUEST_TIMEOUT_SEC=90
GEMINI_CONNECT_TIMEOUT_SEC=15
GEMINI_JSON_MAX_RETRIES=2

# HuggingFace Token for model downloads
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Express.js Webhook Configuration
EXPRESS_WEBHOOK_URL=http://localhost:4000/api/learno/webhook
EXPRESS_WEBHOOK_KEY=CHANGE_ME_use_same_value_as_backend_WEBHOOK_SECRET
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY_SEC=1.0
WEBHOOK_MAX_PAYLOAD_BYTES=15000000
WEBHOOK_RESPONSE_PREVIEW_CHARS=400